{
    "image": "ghcr.io/skillrepos/ai-security-devcontainer:latest",
    "hostRequirements": {
        "cpus": 4,
        "memory": "16gb",
        "storage": "32gb"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "python.terminal.activateEnvInCurrentTerminal": true,
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/py_env/bin/python",
                "github.copilot.enable": {
                    "*": false,
                    "plaintext": false,
                    "markdown": false,
                    "scminput": false
                },
                "github.copilot.enableAutoComplete": false,
                "editor.inlineSuggest.enabled": false,
                "github.copilot.inlineSuggest.enable": false,
                "github.copilot.chat.enable": false,
                "github.copilotChat.showInExplorer": false,
                "workbench.startupEditor": "readme",
                "workbench.editorAssociations": {
                    "*.md": "vscode.markdown.preview.editor"
                }
            },
            "extensions": [
                "mathematic.vscode-pdf"
            ]
        }
    },
    "postCreateCommand": "bash -i scripts/pysetup.sh py_env && bash -i scripts/startOllama.sh && py_env/bin/python scripts/warmup.py",
    "postAttachCommand": "bash scripts/post_attach_ollama.sh"
}
